{
  "version": 7,
  "configurePresets": [
    {
      "name": "windows-2019-debug",
      "displayName": "Windows MSVC 2019 Debug",
      "generator": "Visual Studio 16 2019",
      "binaryDir": "${sourceDir}/build/debug/${presetName}",
      "architecture": { "value": "x64", "strategy": "external" },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_FMT": "ON",
        "ENABLE_FILE_PERSISTENCE": "ON",
        "ENABLE_PYBIND11": "ON"
      }
    },
    {
      "name": "windows-2019-release",
      "displayName": "Windows MSVC 2019 Release",
      "generator": "Visual Studio 16 2019",
      "binaryDir": "${sourceDir}/build/release/${presetName}",
      "architecture": { "value": "x64", "strategy": "external" },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_FMT": "ON",
        "ENABLE_FILE_PERSISTENCE": "ON",
        "ENABLE_PYBIND11": "ON"
      }
    },
    {
      "name": "windows-2022-debug",
      "displayName": "Windows MSVC 2022 Debug",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/debug/${presetName}",
      "architecture": { "value": "x64", "strategy": "external" },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_FMT": "ON",
        "ENABLE_FILE_PERSISTENCE": "ON",
        "ENABLE_PYBIND11": "ON"
      }
    },
    {
      "name": "windows-2022-release",
      "displayName": "Windows MSVC 2022 Release",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/release/${presetName}",
      "architecture": { "value": "x64", "strategy": "external" },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_FMT": "ON",
        "ENABLE_FILE_PERSISTENCE": "ON",
        "ENABLE_PYBIND11": "ON"
      }
    },
    {
      "name": "win32-gcc-x64-mingw-debug",
      "displayName": "Windows MinGW GCC x64 Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug/${presetName}",
      "environment": { "PATH": "C:/msys64/mingw64/bin;$penv{PATH}" },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc.exe",
        "CMAKE_CXX_COMPILER": "g++.exe",
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_FMT": "ON",
        "ENABLE_FILE_PERSISTENCE": "ON",
        "ENABLE_PYBIND11": "ON"
      }
    },
    {
      "name": "win32-gcc-x64-mingw-release",
      "displayName": "Windows MinGW GCC x64 Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release/${presetName}",
      "environment": { "PATH": "C:/msys64/mingw64/bin;$penv{PATH}" },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc.exe",
        "CMAKE_CXX_COMPILER": "g++.exe",
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_FMT": "ON",
        "ENABLE_FILE_PERSISTENCE": "ON",
        "ENABLE_PYBIND11": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "windows-2019-debug",        "configurePreset": "windows-2019-debug",        "configuration": "Debug"   },
    { "name": "windows-2019-release",      "configurePreset": "windows-2019-release",      "configuration": "Release" },
    { "name": "windows-2022-debug",        "configurePreset": "windows-2022-debug",        "configuration": "Debug"   },
    { "name": "windows-2022-release",      "configurePreset": "windows-2022-release",      "configuration": "Release" },
