{
  "version": 7,
  "configurePresets": [
    {
      "name": "gcc-arm-debug",
      "displayName": "GCC ARM Cortex-M4 Debug",
      "generator": "Ninja",
      "toolchainFile": "${sourceDir}/cmake/arm-cortex-gnu/ArmCortexM4Gnu.cmake",
      "binaryDir": "${sourceDir}/build/debug/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_SYSTEM_NAME": "Linux",
        "CMAKE_SYSTEM_PROCESSOR": "armv7l",
        "CMAKE_TRY_COMPILE_TARGET_TYPE": "STATIC_LIBRARY",
        "CMAKE_CROSSCOMPILING": "TRUE"
      }
    },
    {
      "name": "gcc-arm-release",
      "displayName": "GCC ARM Cortex-M4 Release",
      "generator": "Ninja",
      "toolchainFile": "${sourceDir}/cmake/arm-cortex-gnu/ArmCortexM4Gnu.cmake",
      "binaryDir": "${sourceDir}/build/release/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_SYSTEM_NAME": "Linux",
        "CMAKE_SYSTEM_PROCESSOR": "armv7l",
        "CMAKE_TRY_COMPILE_TARGET_TYPE": "STATIC_LIBRARY",
        "CMAKE_CROSSCOMPILING": "TRUE"
      }
    }
  ],
  "buildPresets": [
    { "name": "gcc-arm-debug",   "configurePreset": "gcc-arm-debug"   },
    { "name": "gcc-arm-release", "configurePreset": "gcc-arm-release" }
  ]
}
