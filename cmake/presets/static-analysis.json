{
  "version": 7,
  "configurePresets": [
    {
      "name": "clang-15-debug-static-analysis",
      "displayName": "Clang 15 Debug — Static Analysis",
      "inherits": "clang-15-debug",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-15",
        "CMAKE_CXX_COMPILER": "clang++-15",
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_CPPCHECK": "ON",
        "ENABLE_CLANG_TIDY": "ON",
        "ENABLE_INCLUDE_WHAT_YOU_USE": "ON",
        "ENABLE_COVERAGE": "OFF",
        "ENABLE_SANITIZER_ADDRESS": "OFF",
        "ENABLE_SANITIZER_LEAK": "OFF",
        "ENABLE_SANITIZER_UNDEFINED_BEHAVIOR": "OFF",
        "ENABLE_SANITIZER_MEMORY": "OFF"
      }
    }
  ],
  "buildPresets": [
    { "name": "clang-15-debug-static-analysis", "configurePreset": "clang-15-debug-static-analysis" }
  ]
}
