      "environment": { "CXX": "clang++-12", "CC": "clang-12" }
    },
    {
      "name": "clang-12-release", "inherits": "release-base", "displayName": "Clang 12 Release",
      "environment": { "CXX": "clang++-12", "CC": "clang-12" }
    },
    {
      "name": "clang-13-debug",   "inherits": "debug-base",   "displayName": "Clang 13 Debug",
